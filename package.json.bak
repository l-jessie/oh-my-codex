{
  "name": "ohmycodex",
  "version": "1.0.0",
  "description": "OhMyCodex Desktop — The Unified Codex Desktop Unlocker with native Electron UI",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "build:mac": "tsc && vite build && tsc -p tsconfig.electron.json && electron-builder --mac",
    "start": "node dist/server.js",
    "electron:preview": "npm run build && electron ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "~5.4.0",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "overrides": {
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "ajv-formats": "^3.0.1"
  },
  "build": {
    "appId": "com.ohmycodex.desktop",
    "productName": "OhMyCodex",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "dist-renderer/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "dmg": {
      "title": "OhMyCodex",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
